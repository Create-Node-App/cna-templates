# Environment Variables Example
# Copy to .env for local development
# See: https://docs.astro.build/en/guides/environment-variables/

# Site metadata (optional — override defaults in pages or layouts)
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=My Astro Site

# Feature flags (client-visible vars must use PUBLIC_ prefix)
# PUBLIC_ENABLE_ANALYTICS=false

# Server-only secrets (never prefix with PUBLIC_)
# API_SECRET=

# Never commit sensitive values — use .env.local (gitignored) for secrets

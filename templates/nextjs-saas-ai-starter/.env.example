# =============================================================================
# Next.js SaaS AI Template Environment Variables - Override File
# =============================================================================
# This file documents all available environment variables.
# Copy to .env.local to override the defaults set in .envrc
#
# IMPORTANT: The .envrc file provides sensible defaults for development.
# You only need .env.local for values you want to override (e.g., API keys).
#
# DevContainer users: Most defaults work out of the box!
# =============================================================================

# -----------------------------------------------------------------------------
# Application (defaults in .envrc work for most cases)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME=Next.js SaaS AI Template
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
# DevContainer (auto-detected):
# DATABASE_URL=postgresql://saas_template:saas_template@db:5432/saas_template_dev

# Local Docker:
# DATABASE_URL=postgresql://saas_template:saas_template@localhost:5432/saas_template_dev

# Production (Neon, Supabase, etc.):
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# -----------------------------------------------------------------------------
# Authentication (Auth.js v5)
# -----------------------------------------------------------------------------
# Override the default dev secret with a secure one for production
# Generate with: openssl rand -base64 32
# AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Optional: Override the canonical URL (auto-detected in most cases)
# AUTH_URL=https://saas_template.example.com

# Auth0 Provider (uncomment and fill for SSO)
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# AUTH0_ISSUER=https://your-tenant.auth0.com

# -----------------------------------------------------------------------------
# AI / LLM Configuration (uncomment to enable)
# -----------------------------------------------------------------------------
# OpenAI (for GPT models and embeddings)
# OPENAI_API_KEY=sk-...

# Anthropic (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Enable AI features (set to true when API keys are configured)
# ENABLE_AI_FEATURES=true

# -----------------------------------------------------------------------------
# AWS Configuration (optional)
# -----------------------------------------------------------------------------
# For file uploads (CV, documents) and CloudWatch logging
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=saas_template-uploads

# S3-compatible storage (MinIO for local dev)
# S3_ENDPOINT is the internal endpoint (e.g., http://minio:9000 in Docker)
# S3_PUBLIC_ENDPOINT is the browser-accessible endpoint (e.g., http://localhost:9000)
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# -----------------------------------------------------------------------------
# Development Flags
# -----------------------------------------------------------------------------
# Skip env validation during build (useful for CI)
# SKIP_ENV_VALIDATION=true

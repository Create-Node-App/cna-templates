{
  "name": "nextjs-saas-ai-starter",
  "scripts": {
    "dev": "next dev --turbopack --hostname 0.0.0.0 --port 3000",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "format": "prettier --ignore-path .gitignore --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:a11y": "eslint . --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "test": "jest --runInBand --detectOpenHandles --passWithNoTests",
    "test:watch": "jest -u --runInBand --verbose --watch --detectOpenHandles --passWithNoTests",
    "test:coverage": "jest -u --coverage --verbose --runInBand --detectOpenHandles --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "echo \"db:push is not reliable with this non-public schema setup; running db:migrate instead.\" && pnpm db:migrate",
    "db:push:unsafe": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-demo.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:fresh": "tsx scripts/db-reset.ts --force && tsx scripts/seed-demo.ts",
    "embeddings:generate": "tsx scripts/generate-embeddings.ts",
    "embeddings:recreate": "tsx scripts/generate-embeddings.ts --recreate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },

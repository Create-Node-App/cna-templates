# WebdriverIO environment variables
# Copy to .env for local defaults (loaded by wdio.conf.js via dotenv).
# See config/env.ts and docs/TEST_CONFIGURATION.md for details.

# Execution mode: local (Selenium on this machine) or remote (Selenoid / grid)
MODE=local

# Application under test (WebdriverIO baseUrl in config/wdio.env.conf.ts)
BASE_URL=https://www.google.com

# --- Remote / Selenoid (MODE=remote) ---
SELENIUM_HUB_HOST=localhost
SELENIUM_HUB_PORT=4444
ENABLE_VIDEO=true

# --- Browser selection (set to instance count, e.g. 1) ---
# CHROME=1
# FIREFOX=1
# SAFARI=1
# MOBILE_CHROME=1

# --- Execution tuning ---
# MAX_INSTANCES=3
# BROWSER_VISIBLE=true
# WEBDRIVER_LOGLEVEL=info
# WEBDRIVER_SPEC_FILE_RETRIES=0
# OUTPUT_DIR=./logs
# CONFIGS=

# Environment Variables Example
# Copy this file to .env for local development
# See: https://reactrouter.com/explanation/environment-variables

# Application (server-only unless prefixed with VITE_)
APP_NAME=My App

# Client-exposed variables must use the VITE_ prefix
# VITE_API_BASE_URL=http://localhost:5173/api

# Note: Never commit secrets — use .env.local (gitignored) for sensitive values
